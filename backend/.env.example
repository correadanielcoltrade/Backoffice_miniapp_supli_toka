# ============================================================
#  BACK OFFICE MINI APP TOKA - Variables de entorno (backend)
#  Copia este archivo a .env y completa las credenciales.
# ============================================================

# --- Django ---
SECRET_KEY=cambia-esta-clave-por-una-larga-y-aleatoria
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
# Origenes permitidos para el frontend (React)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Base de datos PostgreSQL ---
DB_NAME=backoffice_toka
DB_USER=postgres
DB_PASSWORD=tu_password_aqui
DB_HOST=127.0.0.1
DB_PORT=5432

# --- Integracion Super App TOKA (firma RSA / OpenAPI) ---
TOKA_ENV=UAT
TOKA_API_BASE_URL=https://openapi.uat.toka.whalecloud.ltd
TOKA_CLIENT_ID=el-client-id-que-te-dio-toka
TOKA_MERCHANT_ID=tu-merchant-id
TOKA_APP_ID=          # appId del mini-program (lo da Toka mas adelante)
# Rutas a los .pem
TOKA_PRIVATE_KEY_PATH=/ruta/a/supli_private_key.pem
TOKA_PUBLIC_KEY_PATH=/ruta/a/supli_public_key.pem
TOKA_TOKA_PUBLIC_KEY_PATH=/ruta/a/toka_public_key.pem
# Pago (Fase 4): URLs de notificacion (webhook) y de retorno tras el checkout
TOKA_PAYMENT_NOTIFY_URL=https://tu-dominio/api/webhooks/toka/payment/
TOKA_PAYMENT_REDIRECT_URL=https://tu-mini-app/checkout/return
# Legado (no se usa con firma RSA)
TOKA_API_KEY=
TOKA_WEBHOOK_SECRET=cambia-este-secreto-del-webhook

# --- JWT ---
ACCESS_TOKEN_LIFETIME_MIN=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# --- BFF mini-app (/v1) ---
SESSION_TOKEN_LIFETIME_MIN=60
# False (por defecto): TODOS los /v1 exigen Bearer sessionToken (salvo auth/session).
# True: catalogo/contenido/ubicaciones son publicos, como propone la spec Wigilabs.
MINIAPP_PUBLIC_CATALOG=True
